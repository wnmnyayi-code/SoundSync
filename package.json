{
  "name": "soundsync",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "db:seed": "npm run generate:local && npm run db:push:local && tsx prisma/seed.ts",
    "db:setup": "prisma generate && prisma db push && npm run db:seed",
    "db:push": "powershell -ExecutionPolicy Bypass -File .\\run-db-push.ps1",
    "db:push:local": "prisma db push --schema prisma/schema.local.prisma",
    "migrate:dev": "powershell -ExecutionPolicy Bypass -File .\\run-migration.ps1",
    "migrate:dev:local": "powershell -ExecutionPolicy Bypass -File .\\run-migration.ps1",
    "migrate:dev:prod": "prisma migrate dev",
    "generate:local": "prisma generate --schema prisma/schema.local.prisma",
    "generate:prod": "prisma generate --schema prisma/schema.prisma"
  },
  "dependencies": {
