    "@tailwindcss/postcss": "^4.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.6",
    "@types/react-dom": "^19.0.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.6",
    "ffmpeg-static": "^5.2.0",
    "postcss": "^8.4.49",
