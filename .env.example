# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Vercel Postgres / Prisma Database URLs
# Get these from your Vercel Postgres dashboard or Prisma Cloud
POSTGRES_URL=postgres://username:password@host:5432/database
POSTGRES_PRISMA_URL=postgres://username:password@host:5432/database
POSTGRES_URL_NON_POOLING=postgres://username:password@host:5432/database

# Optional: Prisma Accelerate (for connection pooling and caching)
PRISMA_DATABASE_URL=prisma+postgres://accelerate.prisma-data.net/?api_key=your_api_key

# Alternative: Standard Database URL (if not using Vercel Postgres)
DATABASE_URL=postgres://username:password@host:5432/database

# =============================================================================
# AUTHENTICATION (NextAuth.js)
# =============================================================================
# Your application URL (update for production)
NEXTAUTH_URL=http://localhost:3000

# Generate a secure secret: openssl rand -base64 32
# REQUIRED: Must be at least 32 characters
NEXTAUTH_SECRET=your_nextauth_secret_here_min_32_chars

# =============================================================================
# ADMIN CREDENTIALS (Exclusive Rights)
# =============================================================================
# Default super admin account credentials
# IMPORTANT: Change these in production!
ADMIN_EMAIL=nipsoul.letsgetit@soundsync.co.za
ADMIN_PASSWORD=Adroit93$$
ADMIN_NAME=SoundSync Administrator

# =============================================================================
# AWS S3 CONFIGURATION
# =============================================================================
# For storing audio files, profile images, and other media
# Create an IAM user with S3 access and get credentials from AWS Console
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET_NAME=soundsync-streams-your-bucket-name

# =============================================================================
# STRIPE PAYMENT INTEGRATION
# =============================================================================
# Get these from https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_/pk_test_) for development
# Use live keys (sk_live_/pk_live_) for production
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Public key for client-side Stripe.js (must start with NEXT_PUBLIC_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook secret for Stripe events (get from Stripe webhook dashboard)
STRIPE_WEBHOOK_SECRET=whsec_...

# Connected account ID for marketplace payments (if using Stripe Connect)
STRIPE_CONNECTED_ACCOUNT_ID=acct_...

# =============================================================================
# EMAIL SERVICE (SendGrid)
# =============================================================================
# For sending verification emails, password resets, notifications
# Get API key from https://app.sendgrid.com/settings/api_keys
# OPTIONAL: If not set, emails will be logged to console
SENDGRID_API_KEY=SG.your_sendgrid_api_key

# Email address to send from (must be verified in SendGrid)
EMAIL_FROM=noreply@yourdomain.com

# =============================================================================
# DRM (Digital Rights Management)
# =============================================================================
# For protecting audio streams during live sessions
# Choose a DRM provider (e.g., BuyDRM, Irdeto, Vualto)
DRM_LICENSE_SERVER=https://your-drm-provider.com/license
DRM_API_KEY=your_drm_api_key

# =============================================================================
# VERCEL CONFIGURATION
# =============================================================================
# Vercel API token for programmatic access
# Get from https://vercel.com/account/tokens
VERCEL_TOKEN=your_vercel_token

# Auto-injected by Vercel (do not set manually)
VERCEL_OIDC_TOKEN=

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# Beta user limit (for limiting registrations during beta phase)
BETA_USER_LIMIT=1000

# Maximum number of users allowed (for trial/beta)
NEXT_PUBLIC_MAX_USERS=1000000


# Node environment (development/production/test)
NODE_ENV=development

# =============================================================================
# OPTIONAL: THIRD-PARTY APIS
# =============================================================================

# Google OAuth (if implementing Google sign-in)
# Get from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Apple OAuth (if implementing Apple sign-in)
# Get from https://developer.apple.com/account/resources/identifiers/list
APPLE_ID=your_apple_id
APPLE_TEAM_ID=your_apple_team_id
APPLE_PRIVATE_KEY=your_apple_private_key
APPLE_KEY_ID=your_apple_key_id

# SAMBRO API (for music rights management in South Africa)
# Contact SAMBRO for API access
SAMBRO_API_KEY=your_sambro_api_key
SAMBRO_API_URL=https://api.sambro.org.za

# SARS API (for tax verification in South Africa)
# Contact SARS for API access
SARS_API_KEY=your_sars_api_key
SARS_API_URL=https://api.sars.gov.za

# Analytics (Google Analytics, Mixpanel, etc.)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_MIXPANEL_TOKEN=your_mixpanel_token

# Error Tracking (Sentry)
NEXT_PUBLIC_SENTRY_DSN=https://your_sentry_dsn
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# File Upload Limits
NEXT_PUBLIC_MAX_FILE_SIZE=104857600
NEXT_PUBLIC_MAX_AUDIO_DURATION=600

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================
# FFmpeg path (for audio processing in development)
FFMPEG_PATH=/usr/local/bin/ffmpeg

# Debug mode
DEBUG=false